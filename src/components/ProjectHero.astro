---
import { ui, type Locale } from "../data/projects";

interface StackRow {
  label: string;
  value: string;
}

interface Props {
  title: string;
  lead: string;
  liveUrl?: string;
  stackRows: StackRow[];
  imageSrc?: string;
  locale?: Locale;
}

const {
  title,
  lead,
  liveUrl,
  stackRows,
  imageSrc = "/placeholder-project.svg",
  locale = "en",
} = Astro.props;
const copy = ui[locale];
const imageAlt =
  locale === "pt" ? `Captura do projeto ${title}` : `${title} project screenshot`;
---

<header class="hero">
  <div class="hero-card">
    <div class="hero-top">
      <div class="hero-top-copy">
        <div class="hero-label">{copy.techStackReview}</div>
        <h1>{title}</h1>
        <p class="lead">{lead}</p>
        {liveUrl && (
          <p class="project-link">
            {copy.liveAt}
            <a href={liveUrl} target="_blank" rel="noreferrer">
              {liveUrl}
            </a>
          </p>
        )}
      </div>
      <div class="hero-image-wrap">
        {liveUrl ? (
          <a
            href={liveUrl}
            target="_blank"
            rel="noreferrer"
            aria-label={`${copy.openLiveSite}: ${title}`}
          >
            <img class="hero-image" src={imageSrc} alt={imageAlt} />
          </a>
        ) : (
          <img class="hero-image" src={imageSrc} alt={imageAlt} />
        )}
      </div>
    </div>
    <div class="hero-summary">
      <aside class="stack-box">
        <h2>{copy.atAGlance}</h2>
        <div class="stack-grid">
          {stackRows.map((row) => (
            <div class="stack-row">
              <strong>{row.label}</strong>
              <span set:html={row.value}></span>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </div>
</header>
