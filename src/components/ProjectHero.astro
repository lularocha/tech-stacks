---
interface StackRow {
  label: string;
  value: string;
}

interface Props {
  title: string;
  lead: string;
  liveUrl?: string;
  stackRows: StackRow[];
}

const { title, lead, liveUrl, stackRows } = Astro.props;
---

<header class="hero">
  <div class="hero-card">
    <div class="hero-inner">
      <div>
        <div class="hero-label">Tech Stack Review</div>
        <h1>{title}</h1>
        <p class="lead">{lead}</p>
        {liveUrl && (
          <p class="project-link">
            Live site:
            <a href={liveUrl} target="_blank" rel="noreferrer">
              {liveUrl}
            </a>
          </p>
        )}
      </div>
      <aside class="stack-box">
        <h2>At a glance</h2>
        <div class="stack-grid">
          {stackRows.map((row) => (
            <div class="stack-row">
              <strong>{row.label}</strong>
              <span set:html={row.value}></span>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </div>
</header>
