---
interface Props {
  title: string;
  summary: string;
  href?: string;
  imageSrc?: string;
  locale?: "en" | "pt";
}

const { title, summary, href, imageSrc, locale = "en" } = Astro.props;
const Tag = href ? "a" : "article";
const imageAlt =
  locale === "pt" ? `Captura do projeto ${title}` : `${title} project screenshot`;
---

<Tag
  class:list={["project-card", href && "project-card-link-card"]}
  href={href}
>
  <div class="project-card-top">
    {imageSrc && (
      <img class="project-card-image" src={imageSrc} alt={imageAlt} />
    )}
    <h2>{title}</h2>
    <p class="lead">{summary}</p>
  </div>
</Tag>
