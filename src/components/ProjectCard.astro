---
interface Props {
  title: string;
  summary: string;
  href?: string;
  imageSrc?: string;
}

const { title, summary, href, imageSrc } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag
  class:list={["project-card", href && "project-card-link-card"]}
  href={href}
>
  <div class="project-card-top">
    {imageSrc && (
      <img class="project-card-image" src={imageSrc} alt={`${title} project screenshot`} />
    )}
    <h2>{title}</h2>
    <p class="lead">{summary}</p>
  </div>
</Tag>
